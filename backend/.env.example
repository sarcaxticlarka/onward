# Copy this file to .env and fill in real values.
# The app runs without any of these set (SQLite fallback DB, LLM calls
# return clear "provider not configured" errors instead of crashing),
# but Supabase + at least one LLM provider key are required for full function.

# --- App ---
ENV=development
DEBUG=true
CORS_ORIGINS=*

# --- Supabase (primary DB + Auth) ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

# --- LLM Providers (LLM Router) ---
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Google Calendar OAuth2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/callback

# --- Redis (Celery job queue / caching) ---
REDIS_URL=redis://localhost:6379/0
